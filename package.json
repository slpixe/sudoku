{
  "name": "sudoku",
  "version": "0.1.0",
  "type": "module",
  "description": "Play over 3,000 Sudoku puzzles from easy to evil. Open source and free with no tracking.",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist/",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest",
    "start": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier:write": "prettier --write './src/**/*.ts' './src/**/*.tsx'",
    "fetch-sudokus": "node --import ./scripts/register_ts_node.mjs --experimental-specifier-resolution=node ./scripts/fetch_sudokus.ts -l 6 -n 100 -p sudokuDotCom",
    "generate-easy-sudokus": "node --import ./scripts/register_ts_node.mjs --experimental-specifier-resolution=node ./scripts/generate_sudokus.ts -d easy -n 500",
    "generate-medium-sudokus": "node --import ./scripts/register_ts_node.mjs --experimental-specifier-resolution=node ./scripts/generate_sudokus.ts -d medium -n 500",
    "generate-hard-sudokus": "node --import ./scripts/register_ts_node.mjs --experimental-specifier-resolution=node ./scripts/generate_sudokus.ts -d hard -n 500",
    "generate-expert-sudokus": "node --import ./scripts/register_ts_node.mjs --experimental-specifier-resolution=node ./scripts/generate_sudokus.ts -d expert -n 500",
    "generate-evil-sudokus": "node --import ./scripts/register_ts_node.mjs --experimental-specifier-resolution=node ./scripts/generate_sudokus.ts -d evil -n 500"
  },
  "keywords": [
    "sudoku",
    "sudoku generator",
    "sudoku solver",
    "sudoku game",
    "online sudoku",
    "sudoku",
    "game"
  ],
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/forms": "0.5.11",
    "@types/lodash-es": "4.17.12",
    "@types/node": "24.3.1",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "@vitejs/plugin-react": "5.2.0",
    "autoprefixer": "10.5.2",
    "cheerio": "1.0.0-rc.12",
    "commander": "12.0.0",
    "eslint": "9.39.4",
    "eslint-plugin-immutable": "1.0.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "16.3.0",
    "postcss": "8.5.16",
    "prettier": "3.2.5",
    "prettier-plugin-tailwindcss": "0.5.14",
    "tailwindcss": "3.4.19",
    "ts-node": "10.9.2",
    "typescript": "5.8.3",
    "vite": "7.3.6",
    "vite-plugin-pwa": "1.3.0",
    "vite-tsconfig-paths": "4.3.2",
    "vitest": "3.2.6",
    "workbox-build": "7.4.1",
    "workbox-window": "7.4.1"
  },
  "dependencies": {
    "@tanstack/react-router": "1.121.34",
    "clsx": "2.1.1",
    "hotkeys-js": "3.13.7",
    "i18next": "25.4.2",
    "lodash-es": "4.18.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "15.7.2",
    "tailwind-merge": "3.3.1"
  }
}
